# Copy to .env and fill in. The platform runs fully without a key
# (the assistant falls back to a deterministic tool-routing stub).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
# Reasoning effort for GPT-5 / o-series models: none | low | medium | high | xhigh
# ("low" keeps the tool-routing assistant fast; ignored for non-reasoning models).
OPENAI_REASONING_EFFORT=low
# Comma-separated allowed origins for CORS (frontend dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Seed for the deterministic synthetic data generator
DATA_SEED=20260615
# Data source: auto (db if alfadev.db exists, else synthetic) | db | synthetic
# Build the real DB with: cd backend && python -m app.data.etl
DATA_SOURCE=auto
